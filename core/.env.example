# Core
OPENAI_API_KEY=
STEER_API_KEY=
STEER_API_ALLOW_NO_KEY=0

# Integrations (Gmail / Notion / Telegram)
# Gmail OAuth desktop credentials JSON path (optional if using ./credentials.json or ./core/credentials.json)
GMAIL_CREDENTIALS_PATH=
# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=
# Optional: direct page append target (if your flow uses page children API)
NOTION_PAGE_ID=
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: only allow this Telegram sender ID for inbound commands
TELEGRAM_USER_ID=
# Enable Telegram long polling listener on core startup (1=on, 0=off)
STEER_TELEGRAM_POLLING=1
# Allow mail-send fresh draft recovery path when marker-scoped/test flow is detected
STEER_MAIL_ALLOW_FRESH_RECOVERY=1
# When 0, mail_send action can proceed on sent_pending and final semantic/mailbox checks decide pass/fail.
STEER_OUTBOUND_MAIL_REQUIRE_SENT_CONFIRMED=0
# Sent mailbox evidence requirement for final judgement (0=allow pending/log-based proof, 1=require Sent mailbox proof).
# When unset, runners auto-follow STEER_OUTBOUND_MAIL_REQUIRE_SENT_CONFIRMED.
STEER_REQUIRE_SENT_MAILBOX_EVIDENCE=0
# Treat "Type permission issue detected" warnings as hard failure (default 0 keeps them as warning if fallback succeeded).
STEER_FAIL_ON_TYPE_PERMISSION_ISSUE=0
# NL request runner guardrails for complex prompts
# STEER_MIN_NL_MAX_STEPS=30
# STEER_ENFORCE_MIN_NL_MAX_STEPS=1
# STEER_NL_COMPLEX_PLAN_TIMEOUT_SEC=45
# STEER_NL_COMPLEX_GOAL_MAX_WALL_SEC=600
# STEER_ENFORCE_MIN_NL_PLAN_TIMEOUT=1
# STEER_MIN_NL_PLAN_TIMEOUT_SEC=30
# STEER_MIN_NL_COMPLEX_PLAN_TIMEOUT_SEC=45
# STEER_ENFORCE_MIN_NL_GOAL_MAX_WALL=1
# STEER_MIN_NL_GOAL_MAX_WALL_SEC=300
# STEER_MIN_NL_COMPLEX_GOAL_MAX_WALL_SEC=600
# CLI LLM timeout guardrails (n8n 요청 시 더 긴 timeout 권장)
# STEER_ENFORCE_MIN_NL_CLI_TIMEOUT=1
# STEER_MIN_NL_CLI_TIMEOUT_SEC=45
# STEER_MIN_NL_N8N_CLI_TIMEOUT_SEC=60
# Run-scope marker injection policy for NL runner (auto skips marker on n8n requests)
STEER_RUN_SCOPE_MARKER_MODE=auto
# n8n 요청 감지 시 실행 완료(success/completed) 증거를 요구 (auto|0|1)
STEER_REQUIRE_N8N_EXECUTION=auto
# 제품 비교/리서치형 복잡 요청을 n8n 경로로 자동 라우팅 (0|1|auto)
STEER_ROUTE_PRODUCT_RESEARCH_TO_N8N=auto

# n8n (recommended defaults for macOS local operation)
STEER_N8N_RUNTIME=manual
STEER_N8N_AUTO_START=0
STEER_N8N_ALLOW_CLI_FALLBACK=0
STEER_N8N_API_URL=http://127.0.0.1:5678/api/v1
N8N_API_URL=http://127.0.0.1:5678/api/v1
STEER_N8N_PREFER_LOCAL_DB_KEY=1
# Wait/poll window to confirm workflow execution finished successfully after approve/trigger
STEER_N8N_AUTO_TRIGGER_EXECUTION_WAIT_SEC=120
STEER_N8N_AUTO_TRIGGER_EXECUTION_POLL_MS=1500
# On LLM workflow-generation failure, fallback orchestrator template (0=disabled, 1=enabled)
STEER_N8N_MINIMAL_ON_LLM_FAILURE=1
# On empty/too-simple workflow JSON, replace with orchestrator fallback (0=fail fast, 1=allow fallback)
STEER_N8N_ALLOW_SIMPLE_WORKFLOW_FALLBACK=1
# Optional explicit local DB path for API key sync (auto-detects ~/.steer/n8n and ~/.n8n when unset)
# STEER_N8N_DB_PATH=/Users/<you>/.steer/n8n/database.sqlite
STEER_N8N_API_KEY=
N8N_API_KEY=

# Collector (avoid 8080 conflict with local LLM servers)
STEER_COLLECTOR_PORT=9100

# Optional overrides
# STEER_N8N_COMPOSE_FILE=/absolute/path/to/docker-compose.yml

# Provisioning watchdogs
STEER_WORKFLOW_PROVISION_REQUESTED_TIMEOUT_SECS=180
STEER_WORKFLOW_PROVISION_IN_PROGRESS_TIMEOUT_SECS=900

# Preflight guardrails (non-test mode should keep these defaults)
STEER_PREFLIGHT_SCREEN_CAPTURE=1
# STEER_ALLOW_SCREEN_CAPTURE_SKIP=0
# Semantic verifier can fallback to per-run logs when AppleScript app scans are flaky.
STEER_SEMANTIC_ALLOW_LOG_EVIDENCE=1
